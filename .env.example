# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Auth provider plan: Google, Kakao, Naver, Email.
# Provider client IDs/secrets are configured in Supabase dashboard, not stored here.
# Add service-role keys only in backend/admin-only contexts and never expose them to the browser.

# Server-only YouTube Data API key for latest Shorts thumbnails on the homepage.
# Do not prefix with NEXT_PUBLIC_; this must stay server-side.
YOUTUBE_API_KEY=your-youtube-data-api-key
